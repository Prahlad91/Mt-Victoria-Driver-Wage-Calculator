{
  "version": 2,
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "dist",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://mt-victoria-wage-calc-api.onrender.com/api/$1"
    },
    {
      "src": "/legacy",
      "dest": "/index.html"
    },
    {
      "src": "/legacy/",
      "dest": "/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
